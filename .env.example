# ─── LLM Provider — pick one ─────────────────────────────────────────────────
# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic (optional — change LLM_MODEL below to use)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Model Selection ──────────────────────────────────────────────────────────
# OpenAI:    gpt-4o-mini  |  gpt-4o
# Anthropic: anthropic/claude-haiku-4-5  |  anthropic/claude-sonnet-4-5
LLM_MODEL=gpt-4o-mini

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here.
TELEGRAM_BOT_TOKEN=

# ─── Database (unified local + Fly when using Neon) ──────────────────────────
# Leave unset to use SQLite file (DB_PATH / catalyst_alpha.db).
# Set to your Neon connection string so laptop + Fly share one Postgres DB:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# If PASSWORD contains @ : # or spaces, percent-encode them (e.g. @ → %40).
# On Fly: fly secrets set DATABASE_URL=postgresql://...   (no extra quotes stored inside the value).
# Use the "pooled" URL from Neon if you prefer (good for many short connections).
#
# One-shot copy local SQLite -> Neon (after DATABASE_URL is set):
#   python scripts/migrate_sqlite_to_neon.py
# See also https://neon.tech/docs/import/import-from-sqlite

# ─── Fly.io (production) ─────────────────────────────────────────────────────
# Copy this file to .env locally. With DATABASE_URL set, Fly only needs that +
# LLM secrets (DB_PATH on the machine is ignored for DB access).
# Enable billing on https://fly.io/dashboard/billing then run:
#   powershell -ExecutionPolicy Bypass -File .\scripts\fly-bootstrap.ps1
# That imports non-comment lines from .env into Fly secrets and deploys.
